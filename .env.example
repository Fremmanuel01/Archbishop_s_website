# Sanity CMS — get these from sanity.io/manage after creating a project
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_write_token_here

# Revalidation webhook secret — set this in Sanity webhook settings too
SANITY_REVALIDATE_SECRET=your_random_secret_here

# Public URL — used for canonical, sitemap, OG tags
NEXT_PUBLIC_SITE_URL=https://archbishopvalokeke.org

# Email (Resend) — required for contact + appointment forms
RESEND_API_KEY=
EMAIL_FROM="Archbishop's Office <noreply@archbishopvalokeke.org>"
CONTACT_INBOX=info@archbishopvalokeke.org
APPOINTMENTS_INBOX=appointments@archbishopvalokeke.org

# Sanity CMS — get these from sanity.io/manage after creating a project
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_write_token_here

# Revalidation webhook secret — set this in Sanity webhook settings too
SANITY_REVALIDATE_SECRET=your_random_secret_here

# Optional: email provider (Resend recommended)
RESEND_API_KEY=
